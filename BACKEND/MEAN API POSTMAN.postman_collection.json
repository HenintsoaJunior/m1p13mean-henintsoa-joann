			"name": "🔐 Auth",
			"item": [
				{
					"name": "Login Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"token\", jsonData.token);",
									"    pm.collectionVariables.set(\"utilisateur_id\", jsonData.utilisateur._id);",
									"    console.log(\"Token enregistré avec succès\");",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"daxido@gmail.com\",\n  \"mot_de_passe\": \"Henintsoa2318\"\n}"
						},
						"url": {
							"raw": "{{authUrl}}/auth/connexion",
							"host": [
								"{{authUrl}}"
							],
							"path": [
								"auth",
								"connexion"
							]
						},
						"description": "⚠️ COMMENCEZ ICI : Connectez-vous avec un compte admin pour obtenir le token JWT.\n\nLe token sera automatiquement enregistré dans la variable de collection et utilisé pour toutes les requêtes suivantes.\n\n📝 Modifiez l'email et le mot_de_passe avec vos identifiants admin."
					},
					"response": []
				}
			]
		},
